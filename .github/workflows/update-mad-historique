name: MAD Historique vers history/

on:
  issues:
    types: [opened]

permissions:
  contents: write
  issues: write

jobs:
  archive-mad:
    # Ne traite que les issues dont le titre commence par MAD-HISTORIQUE
    if: startsWith(github.event.issue.title, 'MAD-HISTORIQUE')
    runs-on: ubuntu-latest
    steps:
      - name: Checkout du depot
        uses: actions/checkout@v4

      - name: Extraire le JSON du corps de l'issue
        env:
          ISSUE_BODY: ${{ github.event.issue.body }}
        run: |
          # Retire d'eventuelles clotures de code ``` ajoutees par Power Automate
          printf '%s' "$ISSUE_BODY" | sed -e 's/^```json//' -e 's/^```//' -e 's/```$//' > payload.json
          # Validation : le contenu doit etre un JSON valide
          jq empty payload.json

      - name: Determiner la cle du millesime (YYYY-MM)
        id: vintage
        env:
          ISSUE_TITLE: ${{ github.event.issue.title }}
        run: |
          # Priorite 1 : meta.situationAu au format DD-MM-YYYY dans le JSON
          SIT=$(jq -r '.meta.situationAu // empty' payload.json)
          if echo "$SIT" | grep -Eq '^[0-9]{2}-[0-9]{2}-[0-9]{4}$'; then
            KEY="${SIT:6:4}-${SIT:3:2}"
          else
            # Priorite 2 : titre de l'issue "MAD-HISTORIQUE|YYYY-MM"
            KEY=$(echo "$ISSUE_TITLE" | grep -oE '[0-9]{4}-[0-9]{2}' | head -1)
          fi
          if [ -z "$KEY" ]; then
            echo "::error::Impossible de determiner le millesime (ni meta.situationAu, ni YYYY-MM dans le titre)."
            exit 1
          fi
          echo "key=$KEY" >> "$GITHUB_OUTPUT"
          echo "Millesime detecte : $KEY"

      - name: Ecrire le fichier historique et regenerer l'index
        env:
          ISSUE_TITLE: ${{ github.event.issue.title }}
        run: |
          mkdir -p history
          TARGET="history/data_${{ steps.vintage.outputs.key }}.json"
          # PROTECTION ANTI-ECRASEMENT : un millesime deja archive n'est JAMAIS remplace,
          # sauf si le titre de l'issue contient explicitement |FORCE (correction volontaire)
          if [ -f "$TARGET" ] && ! echo "$ISSUE_TITLE" | grep -q '|FORCE'; then
            echo "SKIPPED=true" >> "$GITHUB_ENV"
            echo "::notice::$TARGET existe deja — conservation de la version archivee (ajouter |FORCE au titre pour remplacer volontairement)."
          else
            cp payload.json "$TARGET"
            echo "SKIPPED=false" >> "$GITHUB_ENV"
          fi

          # Regenere history/index.json au format attendu par le tableau de bord :
          # tableau simple [{id, madName, periode, file}], trie du plus ANCIEN au plus RECENT
          # (le glob data_AAAA-MM.json est naturellement croissant), file = chemin complet.
          jq -n '[inputs | {
            id:      (input_filename | split("/") | last | rtrimstr(".json")),
            madName: ((.meta.madName // "") | sub("\\.xlsx?$"; "")),
            periode: (.meta.periode // ""),
            file:    input_filename
          }]' history/data_*.json > history/index.json
          jq empty history/index.json
          cat history/index.json

      - name: Commit et push
        run: |
          git config user.name  "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add history/
          git commit -m "MAD historique ${{ steps.vintage.outputs.key }} (issue #${{ github.event.issue.number }})" || echo "Rien a commiter"
          git push

      - name: Clore l'issue avec confirmation
        env:
          GH_TOKEN: ${{ github.token }}
        run: |
          if [ "$SKIPPED" = "true" ]; then
            MSG="🛡 Millésime **${{ steps.vintage.outputs.key }}** déjà archivé — la version existante a été **conservée** (aucun écrasement). Pour remplacer volontairement, ré-archivez avec \`|FORCE\` dans le titre de l'issue."
          else
            MSG="✅ MAD historique **${{ steps.vintage.outputs.key }}** archivé dans \`history/\` et index régénéré. Le sélecteur de millésime du tableau de bord sera à jour après republication de GitHub Pages (1–2 min)."
          fi
          gh issue comment ${{ github.event.issue.number }} --repo ${{ github.repository }} --body "$MSG"
          gh issue close ${{ github.event.issue.number }} --repo ${{ github.repository }}
